# ============================================================
# GLAMCOS PLATFORM — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
API_VERSION=v1

# ── MongoDB Atlas ────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/glamcos?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30
JWT_REFRESH_SECRET=CHANGE_ME_another_long_random_string
JWT_REFRESH_EXPIRE=90d

# ── CORS (your deployed frontend URLs) ──────────────────────
CORS_ORIGIN_USER_APP=https://your-user-app.vercel.app
CORS_ORIGIN_PROVIDER_APP=https://your-provider-app.vercel.app
CORS_ORIGIN_MARKETPLACE_APP=https://your-marketplace-app.vercel.app
CORS_ORIGIN_ADMIN_PANEL=https://your-admin-panel.vercel.app

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── File Upload ──────────────────────────────────────────────
MAX_FILE_UPLOAD=5000000
FILE_UPLOAD_PATH=./public/uploads

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Firebase Admin SDK (for push notifications & Firestore) ──
# Leave blank if not using Firebase features
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as in your service account JSON (with \n line breaks)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Razorpay (Marketplace payments) ──────────────────────────
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) in development, live keys (rzp_live_...) in prod.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
